#!/bin/sh
# One-shot power tuning for the usb-proxy appliance, run once at boot (inittab
# sysinit), before usb-proxy starts.

# --- CPU: offline spare cores -------------------------------------------------
# The Allwinner H2+ is a quad Cortex-A7. usb-proxy is USB-I/O-bound (its threads
# spend their time blocked on USB transfers, not computing), so two cores at the
# lowest OPP comfortably saturate USB 2.0. Offlining the other two removes their
# static/leakage draw on this always-on device. CPU hotplug is supported on
# mainline sunxi H3, and schedutil idles the rest at the lowest frequency.
# To keep all four cores, empty OFFLINE_CPUS.
OFFLINE_CPUS="2 3"
for c in $OFFLINE_CPUS; do
	node="/sys/devices/system/cpu/cpu$c/online"
	[ -w "$node" ] && echo 0 > "$node"
done

# --- Ethernet: turn off the unused PHY's RJ45 LEDs ----------------------------
# The H3 internal Ethernet PHY is already at its lowest-power state at boot: its
# bus clock is gated and it's held in reset by hardware default (verified via the
# CCU regs), and nothing powers it up (emac is disabled in both u-boot and the
# kernel). BUT its RJ45 link LEDs stay lit: the board wires them active-low while
# the EMAC-EPHY syscon register powers up with active-HIGH polarity, pinning the
# LED outputs on. The polarity bit (H3_EPHY_LED_POL, bit17) lives in the syscon
# and takes effect even with the PHY gated/in-reset, so setting it makes the idle
# LED outputs go dark while the PHY stays fully powered down.
#   0x01c00030  EMAC-EPHY syscon   H3_EPHY_LED_POL = BIT(17)
if command -v devmem >/dev/null 2>&1; then
	v=$(devmem 0x01c00030)
	devmem 0x01c00030 32 "$(printf '0x%x' $(( v | 0x20000 )))"
fi

exit 0
