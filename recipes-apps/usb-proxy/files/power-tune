#!/bin/sh
# One-shot power tuning for the usb-proxy appliance, run once at boot (inittab
# sysinit), before usb-proxy starts.
#
# The Allwinner H2+ is a quad Cortex-A7. usb-proxy is USB-I/O-bound (its threads
# spend their time blocked on USB transfers, not computing), so two cores at the
# lowest OPP comfortably saturate USB 2.0. Offlining the other two cores removes
# their static/leakage draw on this always-on device. CPU hotplug is supported
# on mainline sunxi H3, and the cpufreq governor (schedutil) already idles the
# remaining cores at the lowest frequency and only bursts up under load.
#
# To keep all four cores (e.g. if you ever need more throughput), delete this
# line from /etc/inittab or empty OFFLINE_CPUS below.
OFFLINE_CPUS="2 3"

for c in $OFFLINE_CPUS; do
	node="/sys/devices/system/cpu/cpu$c/online"
	[ -w "$node" ] && echo 0 > "$node"
done

exit 0
