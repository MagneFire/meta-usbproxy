#!/bin/sh
# usb-proxy appliance launcher — respawned by /etc/inittab (replaces the old
# systemd unit + Restart=always + udev rule). On each invocation it picks up the
# current UDC and proxies whatever USB device is attached; when the device is
# unplugged or usb-proxy exits, init simply respawns us.
set -u

CONF_DIR=/etc/usb-proxy
LOG_DIR=/var/volatile/log
LOG="$LOG_DIR/usb-proxy.log"
mkdir -p "$LOG_DIR"

# Auto-detect the USB device controller. On mainline sunxi this is
# musb-hdrc.<n>.auto; don't hardcode the instance number.
udc=$(ls /sys/class/udc 2>/dev/null | head -n1)
if [ -z "$udc" ]; then
    echo "[usb-proxy-run] no UDC under /sys/class/udc yet; waiting" >> "$LOG"
    sleep 2
    exit 0
fi

cd "$CONF_DIR" || exit 1
echo "[usb-proxy-run] starting on UDC $udc" >> "$LOG"

# --driver musb-hdrc enables the sunxi-musb-specific code paths in usb-proxy.
# config.json (reset_device_before_proxy=false) is read from CONF_DIR.
exec /usr/bin/usb-proxy \
    --device "$udc" \
    --driver musb-hdrc \
    --enable_customized_config \
    --auto_remap_endpoints >> "$LOG" 2>&1
