#!/bin/sh
# usb-proxy appliance launcher — respawned by /etc/inittab.
#
# This stays deliberately simple: it execs usb-proxy so usb-proxy IS the
# inittab-tracked process (exactly one instance, no orphans). usb-proxy already
# handles device disconnect itself — its libusb hotplug callback fires on
# DEVICE_LEFT and SIGINTs the process — so on unplug it exits and inittab
# respawns us, which re-proxies whatever is attached on replug. This mirrors
# Armbian's systemd "Restart=always" model; no supervisor/restart logic here
# (an earlier background-supervisor version orphaned instances and wedged the
# UDC with "couldn't find an available UDC or it's busy").
#
# Status lines go to stdout (serial console under BusyBox init) and the
# logfile; usb-proxy's own output goes to the logfile only.
set -u

CONF_DIR=/etc/usb-proxy
LOG_DIR=/var/volatile/log
LOG="$LOG_DIR/usb-proxy.log"
mkdir -p "$LOG_DIR"

say() { echo "[usb-proxy-run] $*"; echo "[usb-proxy-run] $*" >> "$LOG"; }

# Need a UDC (gadget controller) to proxy onto.
udc=$(ls /sys/class/udc 2>/dev/null | head -n1)
if [ -z "$udc" ]; then
    say "no UDC under /sys/class/udc yet; retrying"
    sleep 2
    exit 0
fi

# Need a (non-hub) USB device to proxy; otherwise wait and let init respawn us
# (avoids a tight respawn loop when nothing is attached).
have_dev=
for d in /sys/bus/usb/devices/*/idVendor; do
    [ -e "$d" ] || continue
    [ "$(cat "$(dirname "$d")/bDeviceClass" 2>/dev/null)" = "09" ] && continue
    have_dev=1
    break
done
if [ -z "$have_dev" ]; then
    say "no USB device attached to proxy yet; waiting"
    sleep 2
    exit 0
fi

cd "$CONF_DIR" || exit 1
say "exec usb-proxy on UDC $udc"

# exec: replace the shell so usb-proxy is the respawned process. On device
# disconnect it exits and inittab respawns us.
exec /usr/bin/usb-proxy \
    --device "$udc" \
    --driver musb-hdrc \
    --enable_customized_config \
    --auto_remap_endpoints >> "$LOG" 2>&1
