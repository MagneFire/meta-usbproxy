From: usb-proxy appliance <usb-proxy@local>
Subject: [PATCH] dts: orangepi-zero: disable unused wifi(mmc1)+ethernet for faster boot

The SDIO wifi (mmc1) async init blocks ~0.9s before the rootfs mount, and
neither wifi nor ethernet is used by this appliance. Disable both.

Signed-off-by: usb-proxy appliance <usb-proxy@local>
---
--- a/arch/arm/boot/dts/allwinner/sun8i-h2-plus-orangepi-zero.dts	2026-06-25 22:51:46.198616021 +0200
+++ b/arch/arm/boot/dts/allwinner/sun8i-h2-plus-orangepi-zero.dts	2026-06-25 22:51:46.205666068 +0200
@@ -139,7 +139,8 @@
 	phy-handle = <&int_mii_phy>;
 	phy-mode = "mii";
 	allwinner,leds-active-low;
-	status = "okay";
+	/* ethernet unused on this appliance */
+	status = "disabled";
 };
 
 &mmc0 {
@@ -156,7 +157,8 @@
 	bus-width = <4>;
 	max-frequency = <16000000>;
 	non-removable;
-	status = "okay";
+	/* wifi unused; disabling removes ~0.9s of SDIO init at boot */
+	status = "disabled";
 
 	/*
 	 * Explicitly define the sdio device, so that we can add an ethernet
